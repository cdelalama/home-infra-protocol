{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://home-infra-protocol.example/schemas/project-contract.schema.json",
  "title": "Home Infra Protocol Project Contract",
  "type": "object",
  "required": ["id", "name", "repository"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "repository": { "type": "string", "minLength": 1 },
    "services": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "runbooks": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "secret_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "store"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string" },
          "store": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
